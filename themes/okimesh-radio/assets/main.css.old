:root {
  --sans: "IBM Plex Sans", system-ui, sans-serif;
  --mono: "IBM Plex Mono", ui-monospace, monospace;
  --maxw: 1180px;
  --rail: 54px;
}

/* ===== Blue theme — default (OKIMesh logo palette) ===== */
:root,
html[data-theme="blue"] {
  --bg: #081320;
  --bg-2: #0b1829;
  --surface: #0e1e38;
  --surface-2: #112240;
  --border: rgba(120, 160, 210, 0.14);
  --border-bright: rgba(91, 164, 245, 0.32);
  --grid: rgba(120, 160, 210, 0.06);
  --text: #e8f4ff;
  --muted: #90a6c4;
  --faint: #5a7494;
  --signal: #5ba4f5;
  --signal-dim: #2d7dd2;
  --amber: #a8d4ff;
  --glow: rgba(45, 125, 210, 0.22);
  --on-signal: #051221;
}

/* ===== Green theme — signal mint ===== */
html[data-theme="green"] {
  --bg: #0a0d13;
  --bg-2: #0e131b;
  --surface: #121823;
  --surface-2: #161d29;
  --border: rgba(148, 163, 184, 0.12);
  --border-bright: rgba(52, 226, 164, 0.28);
  --grid: rgba(148, 163, 184, 0.06);
  --text: #e8eef5;
  --muted: #93a1b3;
  --faint: #5f6b7c;
  --signal: #34e2a4;
  --signal-dim: #1f8f68;
  --amber: #ffb454;
  --glow: rgba(52, 226, 164, 0.18);
  --on-signal: #04130d;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

a {
  color: inherit;
  text-decoration: none;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px);
  background-size: 56px 56px;
  pointer-events: none;
  z-index: 0;
  -webkit-mask-image: radial-gradient(ellipse 90% 70% at 72% 0%, #000 28%, transparent 78%);
  mask-image: radial-gradient(ellipse 90% 70% at 72% 0%, #000 28%, transparent 78%);
}

/* instrument bezel rail */
.bezel {
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  width: var(--rail);
  border-right: 1px solid var(--border);
  background: var(--bg-2);
  z-index: 40;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 18px 0;
}

.bezel .vtext {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.42em;
  text-transform: uppercase;
  color: var(--faint);
}

.bezel .vtext b {
  color: var(--signal);
  font-weight: 600;
}

.bezel .ticks {
  display: flex;
  flex-direction: column;
  gap: 7px;
  align-items: center;
}

.bezel .ticks i {
  width: 14px;
  height: 1px;
  background: var(--border);
  display: block;
}

.bezel .ticks i:nth-child(5n+1) {
  width: 22px;
  background: var(--faint);
}

.bezel .live {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--signal);
  box-shadow: 0 0 10px var(--signal);
  animation: blink 2.6s steps(1) infinite;
}

.shell {
  padding-left: var(--rail);
  position: relative;
  z-index: 1;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* top status bar */
header.status {
  position: sticky;
  top: 0;
  z-index: 30;
  border-bottom: 1px solid var(--border);
  background: color-mix(in srgb, var(--bg) 82%, transparent);
  backdrop-filter: blur(10px);
  font-family: var(--mono);
}

.status .wrap {
  display: flex;
  align-items: center;
  gap: 20px;
  height: 56px;
}

.status .brand {
  display: flex;
  align-items: center;
  gap: 9px;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.status .brand .glyph {
  width: 16px;
  height: 16px;
}

.status nav {
  display: flex;
  gap: 22px;
  margin-left: 8px;
  font-size: 0.8rem;
}

.status nav a {
  color: var(--muted);
  transition: color 0.15s;
  position: relative;
}

.status nav a::before {
  content: "·";
  position: absolute;
  left: -13px;
  color: var(--faint);
  opacity: 0;
}

.status nav a:hover {
  color: var(--text);
}

.status nav a:hover::before {
  opacity: 1;
}

.status .spacer {
  margin-left: auto;
}

.status .readout {
  font-size: 0.74rem;
  color: var(--faint);
  white-space: nowrap;
}

.status .readout b {
  color: var(--signal);
  font-weight: 500;
}

/* section header = packet/log line */
.seclabel {
  display: flex;
  align-items: center;
  gap: 14px;
  font-family: var(--mono);
  font-size: 0.74rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 26px;
}

.seclabel .idx {
  color: var(--faint);
}

.seclabel .rule {
  flex: 1;
  height: 1px;
  background: repeating-linear-gradient(90deg, var(--border) 0 6px, transparent 6px 12px);
}

.seclabel .tag {
  color: var(--faint);
  font-size: 0.7rem;
}

/* hero */
.hero {
  position: relative;
  padding: clamp(56px, 11vw, 124px) 0 clamp(40px, 7vw, 78px);
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  gap: 28px;
  align-items: center;
}

.coord {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--faint);
  letter-spacing: 0.14em;
  margin-bottom: 22px;
}

.coord b {
  color: var(--signal);
  font-weight: 500;
}

.hero h1 {
  font-size: clamp(2.5rem, 6.4vw, 4.9rem);
  line-height: 0.98;
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 24px;
}

.hero h1 .l2 {
  display: block;
  color: var(--signal);
}

.hero .lede {
  font-size: 1.12rem;
  color: var(--muted);
  max-width: 50ch;
  margin-bottom: 30px;
}

.hero .lede b {
  color: var(--text);
  font-weight: 600;
}

.actions {
  display: flex;
  border: 1px solid var(--border);
  width: fit-content;
  max-width: 100%;
}

.actions a {
  font-family: var(--mono);
  font-size: 0.86rem;
  padding: 13px 22px;
  transition: background 0.16s, color 0.16s;
}

.actions a+a {
  border-left: 1px solid var(--border);
}

.actions .go {
  background: var(--signal);
  color: var(--on-signal);
  font-weight: 600;
}

.actions .go:hover {
  background: var(--text);
}

.actions .alt {
  color: var(--text);
}

.actions .alt:hover {
  background: var(--surface);
  color: var(--signal);
}

.scope {
  position: relative;
  border: 1px solid var(--border);
  background: linear-gradient(180deg, var(--bg-2), var(--bg));
  aspect-ratio: 1 / 1;
}

.scope::before,
.scope::after {
  content: "";
  position: absolute;
  width: 9px;
  height: 9px;
  border: 1px solid var(--signal);
}

.scope::before {
  top: -1px;
  left: -1px;
  border-right: 0;
  border-bottom: 0;
}

.scope::after {
  bottom: -1px;
  right: -1px;
  border-left: 0;
  border-top: 0;
}

.scope .cap {
  position: absolute;
  top: 9px;
  left: 11px;
  font-family: var(--mono);
  font-size: 0.66rem;
  color: var(--faint);
  letter-spacing: 0.16em;
  z-index: 2;
}

.scope .cap b {
  color: var(--signal);
}

.scope svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* mission manifesto */
.mission {
  padding: clamp(50px, 8vw, 88px) 0;
  border-bottom: 1px solid var(--border);
}

.mission .lead {
  font-size: clamp(1.4rem, 2.9vw, 2.15rem);
  line-height: 1.3;
  font-weight: 600;
  letter-spacing: -0.015em;
  max-width: 24ch;
  color: var(--text);
}

.mission .body {
  margin-top: 22px;
  font-size: clamp(1rem, 1.5vw, 1.12rem);
  line-height: 1.65;
  color: var(--muted);
  max-width: 60ch;
}

.mission .body .start {
  font-family: var(--mono);
  font-size: 0.82em;
  letter-spacing: 0.04em;
  color: var(--faint);
  text-transform: uppercase;
}

.mission .lead {
  max-width: 30ch;
}

.ac {
  color: var(--signal);
}

/* mission = [00] directive */
.mission {
  padding: clamp(46px, 7vw, 80px) 0 clamp(20px, 4vw, 40px);
}

.mission-body {
  border-left: 2px solid var(--signal);
  padding-left: clamp(20px, 4vw, 44px);
}

.mission .stmt {
  font-size: clamp(1.5rem, 3.3vw, 2.55rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.16;
  max-width: 32ch;
}

.mission .mbody {
  margin-top: 22px;
  font-size: 1.04rem;
  line-height: 1.7;
  color: var(--muted);
  max-width: 72ch;
}

.mission .ac {
  color: var(--signal);
}

.mission .stmt .ac {
  font-weight: 700;
}

.mission .start {
  color: var(--text);
  font-family: var(--mono);
  font-size: 0.82em;
  letter-spacing: 0.04em;
}

/* node registry */
.registry {
  padding: clamp(50px, 8vw, 88px) 0;
}

.reg-table {
  border: 1px solid var(--border);
  border-bottom: 0;
}

.reg-row {
  display: grid;
  grid-template-columns: 64px minmax(0, 1fr) minmax(0, 1.6fr) 96px;
  gap: 18px;
  align-items: center;
  padding: 22px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}

.reg-row:hover {
  background: var(--surface);
}

.reg-row .id {
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--signal);
}

.reg-row .nm {
  font-size: 1.15rem;
  font-weight: 600;
}

.reg-row .ds {
  color: var(--muted);
  font-size: 0.95rem;
}

.reg-row .act {
  font-family: var(--mono);
  font-size: 0.78rem;
  color: var(--faint);
  text-align: right;
  white-space: nowrap;
}

.reg-row:hover .act {
  color: var(--signal);
}

.reg-row:hover .act::after {
  content: " \2192";
}

/* explainer */
.explainer {
  padding: clamp(50px, 8vw, 88px) 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--bg-2);
}

.explainer .grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(30px, 5vw, 60px);
  align-items: start;
}

.explainer h2 {
  font-size: clamp(1.7rem, 3.4vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.015em;
  margin-bottom: 14px;
}

.explainer .prose {
  color: var(--muted);
  font-size: 1.05rem;
}

.specs {
  display: grid;
  border: 1px solid var(--border);
}

.specs .sp {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 14px;
  padding: 16px 18px;
}

.specs .sp+.sp {
  border-top: 1px solid var(--border);
}

.specs .sp .k {
  color: var(--signal);
  font-family: var(--mono);
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  padding-top: 2px;
}

.specs .sp b {
  color: var(--text);
  font-weight: 600;
}

.specs .sp .v {
  color: var(--muted);
}

/* CTA = transmit block */
.transmit {
  padding: clamp(56px, 9vw, 98px) 0;
}

.transmit .box {
  border: 1px solid var(--border-bright);
  padding: clamp(30px, 5vw, 56px);
  position: relative;
  background: linear-gradient(135deg, var(--surface), var(--bg));
}

.transmit .box::before {
  content: "\25CF TX";
  position: absolute;
  top: 14px;
  right: 16px;
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--signal);
  letter-spacing: 0.1em;
}

.transmit h2 {
  font-size: clamp(1.8rem, 4vw, 2.9rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 14px;
  max-width: 18ch;
}

.transmit p {
  color: var(--muted);
  max-width: 52ch;
  margin-bottom: 28px;
}

/* footer = status line */
footer.bar {
  border-top: 1px solid var(--border);
  background: var(--bg-2);
  font-family: var(--mono);
}

footer.bar .wrap {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16px 26px;
  padding-top: 24px;
  padding-bottom: 24px;
}

footer.bar .b {
  display: flex;
  align-items: center;
  gap: 9px;
  font-weight: 600;
}

footer.bar .links {
  display: flex;
  gap: 22px;
}

footer.bar a {
  color: var(--muted);
  font-size: 0.82rem;
  transition: color 0.15s;
}

footer.bar a:hover {
  color: var(--signal);
}

footer.bar .meta {
  margin-left: auto;
  font-size: 0.72rem;
  color: var(--faint);
}

/* theme-driven SVG */
.scope svg line,
.node-panel svg line {
  stroke: var(--signal);
}

.scope svg circle,
.node-panel svg circle {
  fill: var(--signal);
}

.scope svg .edge,
.node-panel svg .edge {
  stroke: var(--signal-dim);
  opacity: 0.55;
}

.scope svg .pkt {
  fill: var(--amber);
}

.node-panel svg rect {
  fill: var(--surface);
}

.node-panel svg text {
  fill: var(--faint);
}

/* theme picker */
.theme-pick {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.theme-pick .sw {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid transparent;
  padding: 0;
  cursor: pointer;
  outline: none;
  transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
}

.theme-pick .sw:hover {
  transform: scale(1.15);
}

.theme-pick .sw:focus-visible {
  box-shadow: 0 0 0 3px var(--glow);
}

.theme-pick .sw-blue {
  background: #5ba4f5;
}

.theme-pick .sw-green {
  background: #34e2a4;
}

.theme-pick .sw[aria-pressed="true"] {
  border-color: var(--text);
  box-shadow: 0 0 10px var(--glow);
}

/* content pages */
.page {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.page-head {
  max-width: 70ch;
  margin-bottom: 34px;
}

.page-head h1 {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 10px 0;
}

.prose {
  max-width: 72ch;
  color: var(--muted);
  font-size: 1.05rem;
}

.prose>*+* {
  margin-top: 1.1em;
}

.prose h2 {
  color: var(--text);
  font-size: 1.55rem;
  font-weight: 700;
  margin-top: 1.7em;
}

.prose h3 {
  color: var(--text);
  font-size: 1.2rem;
  font-weight: 600;
  margin-top: 1.4em;
}

.prose a {
  color: var(--signal);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--signal-dim);
}

.prose a:hover {
  text-decoration-color: var(--signal);
}

.prose strong {
  color: var(--text);
}

.prose ul,
.prose ol {
  padding-left: 1.4em;
}

.prose li {
  margin-top: 0.4em;
}

.prose code {
  font-family: var(--mono);
  font-size: 0.9em;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.1em 0.4em;
  border-radius: 5px;
  color: var(--signal);
}

.prose pre {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 18px 20px;
  overflow-x: auto;
}

.prose pre code {
  background: none;
  border: none;
  padding: 0;
  color: var(--text);
}

.prose blockquote {
  border-left: 2px solid var(--signal-dim);
  padding-left: 18px;
  color: var(--faint);
}

.post-list {
  max-width: 800px;
  border: 1px solid var(--border);
  border-bottom: 0;
}

.post-row {
  display: flex;
  align-items: baseline;
  gap: 18px;
  padding: 18px 20px;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}

.post-row:hover {
  background: var(--surface);
}

.post-row .date {
  font-family: var(--mono);
  font-size: 0.76rem;
  color: var(--faint);
  flex-shrink: 0;
  width: 104px;
}

.post-row .t {
  font-size: 1.08rem;
  color: var(--text);
  font-weight: 500;
}

.post-row .t span {
  display: block;
  font-size: 0.92rem;
  color: var(--muted);
  font-weight: 400;
  margin-top: 3px;
}

.nf {
  min-height: 56vh;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 14px;
}

.nf .code {
  font-family: var(--mono);
  font-size: clamp(3rem, 10vw, 6rem);
  color: var(--signal);
  font-weight: 600;
  letter-spacing: -0.02em;
}

.nf p {
  color: var(--muted);
  font-family: var(--mono);
}

@keyframes blink {

  0%,
  64% {
    opacity: 1;
  }

  65%,
  100% {
    opacity: 0.18;
  }
}

@keyframes dash {
  to {
    stroke-dashoffset: -1000;
  }
}

.pulse-node {
  transform-box: fill-box;
  transform-origin: center;
  animation: np 3s ease-in-out infinite;
}

.pulse-node.b {
  animation-delay: 1s;
}

.pulse-node.c {
  animation-delay: 2s;
}

@keyframes np {

  0%,
  100% {
    opacity: 0.95;
  }

  50% {
    opacity: 0.35;
  }
}

.pkt {
  animation: dash 7s linear infinite;
}

@media (prefers-reduced-motion: reduce) {

  *,
  *::before,
  *::after {
    animation: none !important;
  }
}

@media (max-width: 880px) {
  .bezel {
    display: none;
  }

  .shell {
    padding-left: 0;
  }

  .status nav,
  .status .readout {
    display: none;
  }

  .hero-grid {
    grid-template-columns: 1fr;
    gap: 36px;
  }

  .scope {
    max-width: 420px;
  }

  .explainer .grid {
    grid-template-columns: 1fr;
  }

  .reg-row {
    grid-template-columns: 44px 1fr;
    gap: 6px 14px;
  }

  .reg-row .ds,
  .reg-row .act {
    grid-column: 2;
  }

  .reg-row .act {
    text-align: left;
  }
}

/* ===== live network graph ===== */
.netgraph {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.netgraph svg {
  display: block;
}

.netgraph-full {
  position: relative;
  height: 72vh;
  min-height: 460px;
  border: 1px solid var(--border);
  background:
    radial-gradient(ellipse 80% 80% at 50% 40%, var(--bg-2), var(--bg));
}

.net-tip {
  position: absolute;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.12s;
  background: var(--surface-2);
  border: 1px solid var(--border-bright);
  border-radius: 6px;
  padding: 7px 10px;
  font-family: var(--mono);
  font-size: 0.74rem;
  color: var(--text);
  z-index: 5;
  white-space: nowrap;
  box-shadow: 0 6px 24px rgba(0, 0, 0, 0.4);
}

.net-tip b {
  display: block;
  color: var(--signal);
  font-weight: 600;
}

.net-tip span {
  color: var(--muted);
}

.net-err {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--faint);
}

.net-legend {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  margin-top: 16px;
  font-family: var(--mono);
  font-size: 0.76rem;
  color: var(--muted);
}

.net-legend i {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: 6px;
  vertical-align: middle;
}

.net-legend .rp {
  background: var(--signal);
}

.net-legend .rm {
  background: var(--amber);
}

.net-legend .cp {
  background: var(--signal-dim);
}


.map-embed {
  flex: 1;
  min-height: 480px;
}

.map-embed iframe {
  width: 100%;
  height: 100%;
  display: block;
  border: 0;
}